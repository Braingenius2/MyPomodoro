{
  "name": "my-pomodoro",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @my-pomodoro/web dev",
    "build": "pnpm --filter @my-pomodoro/web build",
    "lint": "pnpm --filter @my-pomodoro/web lint",
    "test": "pnpm --filter @my-pomodoro/web test",
    "test:ui": "pnpm --filter @my-pomodoro/web test:ui",
    "typecheck": "pnpm --filter @my-pomodoro/web exec tsc --noEmit",
    "tauri:dev": "pnpm --filter @my-pomodoro/web tauri dev",
    "tauri:build": "pnpm --filter @my-pomodoro/web tauri build",
    "tauri:android:dev": "pnpm --filter @my-pomodoro/web tauri android dev",
    "tauri:android:build": "pnpm --filter @my-pomodoro/web tauri android build"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
